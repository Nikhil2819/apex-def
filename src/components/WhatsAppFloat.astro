---
import { waLink } from '../data/site.js';
interface Props { hidden?: boolean }
const { hidden = false } = Astro.props;
---

{!hidden && (
  <a
    class="wa-float desktop-only"
    href={waLink()}
    target="_blank"
    rel="noopener"
    aria-label="Chat with APEX D.E.F on WhatsApp"
    data-wa-float
  >
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.7.8-.8 1-.2.2-.3.2-.6.1a6.7 6.7 0 0 1-3.3-2.9c-.3-.4 0-.5.1-.7l.5-.6c.1-.2.1-.3.2-.5s0-.4 0-.5c0-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3a3 3 0 0 0-1 2.2c0 1.3 1 2.6 1.1 2.8.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.2-.2-.5-.3z"/></svg>
  </a>
)}

<style>
  .wa-float {
    position: fixed;
    right: 32px;
    bottom: 32px;
    z-index: 90;
    width: 56px;
    height: 56px;
    border-radius: var(--r-pill);
    background: #25d366;
    color: #fff;
    align-items: center;
    justify-content: center;
    box-shadow: var(--e-3), 0 0 20px rgba(37, 211, 102, 0.25);
    opacity: 0;
    transform: scale(0.6);
    pointer-events: none;
    transition: opacity var(--t-base) var(--ease-out), transform var(--t-base) var(--ease-out);
  }
  .wa-float.is-visible { opacity: 1; transform: scale(1); pointer-events: auto; }
  .wa-float:hover { background: #1fbd5a; }
  @media (min-width: 1024px) {
    .wa-float { display: flex; }
  }
  html[data-tier='static'] .wa-float { opacity: 1; transform: none; pointer-events: auto; }
</style>
