---
// #story authored vector facility scene (design.md §4.2 / DECISIONS.md #18):
// silhouette/gradient plant with storage tanks in the brand palette — same
// design language as PackVisual (1.5px strokes, HDPE-gradient fills, def-400
// accents). Drawn scene in place of photography at launch.
---

<svg
  class="facility-scene"
  viewBox="0 0 560 250"
  role="img"
  aria-label="Illustration: Apex Environment Solutions production facility with storage tanks"
>
  <defs>
    <linearGradient id="fac-body" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#1B4F9C"></stop>
      <stop offset="1" stop-color="#0A1B3D"></stop>
    </linearGradient>
    <linearGradient id="fac-tank" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#16407E"></stop>
      <stop offset="1" stop-color="#0A1B3D"></stop>
    </linearGradient>
  </defs>

  <!-- urea hexagon motif, faint -->
  <g stroke="rgba(47,182,233,0.16)" stroke-width="1.5" fill="none">
    <path d="M472 28l12 7v14l-12 7-12-7V35Z"></path>
    <path d="M500 46l9 5.2v10.4l-9 5.2-9-5.2V51.2Z"></path>
  </g>

  <!-- stack -->
  <rect x="96" y="52" width="13" height="52" fill="url(#fac-body)"></rect>
  <path d="M96 62h13" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"></path>

  <!-- main production hall, accent roofline echoing the pack lids -->
  <rect x="50" y="100" width="210" height="100" rx="6" fill="url(#fac-body)"></rect>
  <rect x="50" y="100" width="210" height="9" rx="4.5" fill="#2FB6E9"></rect>
  <!-- clerestory windows -->
  <g fill="rgba(47,182,233,0.16)" stroke="rgba(47,182,233,0.4)" stroke-width="1.5">
    <rect x="68" y="124" width="36" height="22" rx="3"></rect>
    <rect x="116" y="124" width="36" height="22" rx="3"></rect>
    <rect x="164" y="124" width="36" height="22" rx="3"></rect>
  </g>
  <!-- door -->
  <rect x="216" y="158" width="28" height="42" rx="3" fill="rgba(6,11,20,0.5)" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"></rect>
  <!-- wall sign: droplet on white panel -->
  <rect x="70" y="162" width="60" height="26" rx="4" fill="#FFFFFF"></rect>
  <path
    d="M84 168c2.4 3 3.7 5 3.7 6.7a3.7 3.7 0 1 1-7.4 0c0-1.7 1.3-3.7 3.7-6.7Z"
    fill="#1B4F9C"></path>
  <text
    x="107"
    y="179"
    text-anchor="middle"
    fill="#0A1B3D"
    font-size="8"
    style="font-family: var(--font-display), sans-serif; font-weight: 600; letter-spacing: 0.02em;"
    >APEX D.E.F</text>

  <!-- transfer pipe with valve -->
  <path d="M260 150h46v50" fill="none" stroke="#8FA3B8" stroke-width="1.5" stroke-linecap="round"></path>
  <circle cx="284" cy="150" r="4" fill="none" stroke="#8FA3B8" stroke-width="1.5"></circle>

  <!-- storage tanks with accent caps -->
  <rect x="344" y="88" width="17" height="9" rx="2.5" fill="#2FB6E9"></rect>
  <rect x="320" y="96" width="66" height="104" rx="8" fill="url(#fac-tank)" stroke="rgba(255,255,255,0.16)" stroke-width="1.5"></rect>
  <path d="M320 132h66M320 166h66" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"></path>
  <rect x="414" y="108" width="15" height="9" rx="2.5" fill="#2FB6E9"></rect>
  <rect x="396" y="116" width="52" height="84" rx="7" fill="url(#fac-tank)" stroke="rgba(255,255,255,0.16)" stroke-width="1.5"></rect>
  <path d="M396 146h52M396 174h52" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"></path>

  <!-- boundary fence -->
  <path d="M468 200v-16M486 200v-16M504 200v-16" stroke="rgba(255,255,255,0.16)" stroke-width="1.5"></path>
  <path d="M462 190h48" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"></path>

  <!-- ground line -->
  <path d="M30 200h500" stroke="rgba(255,255,255,0.25)" stroke-width="1.5" stroke-linecap="round"></path>
</svg>

<style>
  .facility-scene {
    width: 100%;
    height: auto;
  }
</style>
