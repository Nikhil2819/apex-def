---
import '../styles/global.css';
import { tierScript } from '../scripts/tier.js';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileCtaBar from '../components/MobileCtaBar.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { site } from '../data/site.js';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  /** Path of this page, e.g. '/products' — used for canonical + active nav */
  path: string;
  /** Optional JSON-LD object(s) rendered as a single @graph script */
  schema?: object | null;
  /** 'dark' pages start under a transparent header over a dark hero */
  headerTheme?: 'dark' | 'light';
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  path,
  schema = null,
  headerTheme = 'dark',
} = Astro.props;

const canonical = new URL(path === '/' ? '/' : path, site.domain).href;
---

<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="APEX D.E.F" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og-default.jpg', site.domain).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preload" href="/fonts/clash-display-600.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/clash-display-500.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline set:html={tierScript} />
    <script is:inline>
      // Reveal bootstrap: anything near the first viewport becomes visible the
      // moment parsing finishes (readyState 'interactive') — unlike
      // DOMContentLoaded, this does NOT wait for deferred module scripts, so
      // the LCP never waits for the JS bundle on slow networks.
      (function () {
        function boot() {
          if (document.documentElement.dataset.tier === 'static') return;
          requestAnimationFrame(function () {
            var vh = innerHeight * 1.2;
            document.querySelectorAll('[data-reveal]').forEach(function (el) {
              if (el.getBoundingClientRect().top < vh) el.classList.add('is-revealed');
            });
          });
        }
        if (document.readyState !== 'loading') return boot();
        document.addEventListener('readystatechange', function h() {
          if (document.readyState !== 'loading') {
            document.removeEventListener('readystatechange', h);
            boot();
          }
        });
      })();
    </script>
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    <style>
      @view-transition { navigation: auto; }
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root), ::view-transition-new(root) { animation: none; }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header path={path} theme={headerTheme} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <aside aria-label="Quick contact">
      <MobileCtaBar />
      <WhatsAppFloat hidden={path === '/contact'} />
    </aside>
    <script>
      import '../scripts/app.js';
    </script>
  </body>
</html>
