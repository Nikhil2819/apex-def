---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="APEX D.E.F | DEF (Diesel Exhaust Fluid) Manufacturer India"
  description="ISO 22241 / IS 17042 Diesel Exhaust Fluid made in Bulandshahr, UP. Packs from 5 L to bulk tanker. Lab-tested every batch. Call or WhatsApp APEX D.E.F."
  ogTitle="APEX D.E.F — Diesel Exhaust Fluid, made to the numbers."
  ogDescription="32.5% urea. 67.5% demin water. Zero shortcuts. Lab-tested DEF from Bulandshahr for tractors, trucks, machines and gensets."
  path="/"
>
  <section id="hero" class="section--dark" style="min-height: 100svh; display: grid; place-items: center; padding-top: var(--header-h-mobile);">
    <div class="container" style="text-align: center;">
      <p class="chip chip--dark" data-reveal>DEF · AUS 32 · Made in India</p>
      <h1 class="display-1" style="margin-block: var(--sp-5); --reveal-delay: 1;" data-reveal>
        32.5% urea. 67.5% demin water.<br /><span class="grad-text">Zero shortcuts.</span>
      </h1>
      <p class="lead muted" style="max-width: 56ch; margin-inline: auto;" data-reveal>
        APEX D.E.F manufactures ISO 22241 / IS 17042-grade Diesel Exhaust Fluid in Bulandshahr,
        Uttar Pradesh — for tractors, trucks, construction machines and gensets across India.
      </p>
    </div>
  </section>
  <!-- Phase 2 fills: #intro #stats #products #applications #how-it-works #why-apex #quality #marquee #faq #dealer-cta #contact-strip -->
</BaseLayout>
