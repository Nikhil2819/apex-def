---
import Logo from './Logo.astro';
import { nav, site } from '../data/site.js';

interface Props {
  path: string;
  theme?: 'dark' | 'light';
}
const { path, theme = 'dark' } = Astro.props;
const primaryPhone = site.phones[0];
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class={`site-header theme-${theme}`} id="site-header" data-header>
  <div class="header-inner container container--max">
    <Logo />
    <nav class="main-nav desktop-only" aria-label="Main">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} class:list={[{ active: isActive(item.href) }]} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="header-actions">
      <a class="btn btn--primary-dark header-call desktop-only" href={`tel:${primaryPhone.tel}`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call Now
      </a>
      <a class="icon-btn mobile-call" href={`tel:${primaryPhone.tel}`} aria-label={`Call ${primaryPhone.display}`}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
      <button class="icon-btn menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" data-menu-toggle>
        <svg class="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
        <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="5" x2="19" y2="19"/><line x1="19" y1="5" x2="5" y2="19"/></svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
    <nav aria-label="Mobile">
      <ul>
        {nav.map((item, i) => (
          <li style={`--i:${i}`}>
            <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="mobile-menu-contact">
      {site.phones.map((p) => (
        <a href={`tel:${p.tel}`} class="tnum">{p.display}</a>
      ))}
      <p class="small">{site.address.short}</p>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: var(--header-h-mobile);
    color: #fff;
    background: rgba(6, 11, 20, 0.55);
    border-bottom: 1px solid var(--hairline-dark);
    transition: height var(--t-base) var(--ease-out-soft), transform var(--t-base) var(--ease-out-soft), background var(--t-base);
  }
  @supports (backdrop-filter: blur(14px)) {
    .site-header { backdrop-filter: blur(14px) saturate(1.2); }
  }
  @supports not (backdrop-filter: blur(14px)) {
    .site-header { background: rgba(6, 11, 20, 0.92); }
  }
  .site-header.is-hidden { transform: translateY(-100%); }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
    height: 100%;
  }
  .main-nav ul { display: flex; align-items: center; gap: clamp(20px, 2vw, 32px); list-style: none; padding: 0; }
  .main-nav a {
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    padding-block: 6px;
    background-image: linear-gradient(var(--def-400), var(--def-400));
    background-repeat: no-repeat;
    background-size: 0% 2px;
    background-position: left bottom;
    transition: background-size var(--t-base) var(--ease-out-soft), color var(--t-fast);
  }
  .main-nav a:hover { color: #fff; background-size: 100% 2px; }
  .main-nav a.active { color: #fff; background-size: 100% 2px; }
  .header-actions { display: flex; align-items: center; gap: var(--sp-3); }
  .header-call { padding: 10px 22px; min-height: 44px; font-size: 0.875rem; }
  .icon-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; border-radius: var(--r-pill); color: #fff;
  }
  .icon-btn:hover { background: rgba(255, 255, 255, 0.08); }
  .mobile-call { display: inline-flex; }
  .menu-toggle { display: inline-flex; }
  .menu-toggle .icon-close { display: none; }
  .menu-toggle[aria-expanded='true'] .icon-open { display: none; }
  .menu-toggle[aria-expanded='true'] .icon-close { display: block; }

  @media (min-width: 1024px) {
    .site-header { height: var(--header-h); }
    .site-header.is-shrunk { height: var(--header-h-shrunk); }
    .mobile-call, .menu-toggle { display: none; }
  }

  /* Mobile menu overlay */
  .mobile-menu[hidden] { display: none; }
  .mobile-menu {
    position: fixed;
    inset: var(--header-h-mobile) 0 0 0;
    background: var(--ink-950);
    padding: var(--sp-7) 24px calc(var(--mobile-bar-h) + var(--sp-7));
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--sp-7);
  }
  .mobile-menu ul { list-style: none; padding: 0; display: grid; gap: var(--sp-4); }
  .mobile-menu nav a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.75rem, 7vw, 2.5rem);
    letter-spacing: -0.02em;
    color: #fff;
    text-decoration: none;
    display: block;
    padding-block: 4px;
  }
  .mobile-menu nav a.active { color: var(--def-400); }
  html[data-tier='full'] .mobile-menu li, html[data-tier='lite'] .mobile-menu li {
    animation: menu-item-in 0.45s var(--ease-out) both;
    animation-delay: calc(var(--i) * 0.06s);
  }
  @keyframes menu-item-in {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mobile-menu li { animation: none !important; }
  }
  .mobile-menu-contact { display: grid; gap: var(--sp-2); color: rgba(255, 255, 255, 0.72); }
  .mobile-menu-contact a { color: var(--def-400); font-weight: 600; font-size: 1.125rem; text-decoration: none; }
</style>
