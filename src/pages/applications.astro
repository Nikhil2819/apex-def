  description="DEF for TREM IV tractors, BS-VI trucks &amp; buses, CEV IV construction machines and CPCB IV+ gensets. Dosing guidance and right pack sizes for each duty."
  path="/applications"
>
  <section class="section--dark" style="padding-top: calc(var(--header-h-mobile) + var(--sp-8)); min-height: 60svh;">
    <div class="container">
      <p class="overline" data-reveal>Applications</p>
      <h1 class="display-2" style="margin-top: var(--sp-4); max-width: 18ch;" data-reveal>Built for every duty cycle that burns diesel.</h1>
    </div>
  </section>
  <!-- Phase 2 fills the remaining sections per content.md -->
</BaseLayout>
