---
// DealerHeroArt — authored warehouse supply-chain scene for /dealers #opportunity
// (design.md §4.6: "authored vector supply-chain illustration — drum/IBC warehouse
// silhouette scene, brand palette, 1.5px-stroke + gradient style"). Drawn to the
// PackVisual style contract: HDPE body gradient #1B4F9C→#0A1B3D, #2FB6E9 accents,
// #8FA3B8 metal strokes at 1.5px, floor-shadow ellipses, no filters.

const ACCENT = '#2FB6E9';
const NAVY = '#0A1B3D';
const METAL = '#8FA3B8';
const RIB = '#123A72';

const defs =
  '<defs>' +
  '<linearGradient id="dw-drum" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#1B4F9C"/><stop offset="1" stop-color="#0A1B3D"/></linearGradient>' +
  '<linearGradient id="dw-ibc" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#E8F0F8"/><stop offset="1" stop-color="#BFD3E6"/></linearGradient>' +
  '<radialGradient id="dw-glow" cx="0.5" cy="0.5" r="0.5"><stop offset="0" stop-color="#2FB6E9" stop-opacity="0.22"/><stop offset="1" stop-color="#2FB6E9" stop-opacity="0"/></radialGradient>' +
  '</defs>';

// 210 L drum, 64×88, PackVisual def-210l geometry at reduced scale.
const drum = (x: number, y: number) =>
  `<rect x="${x}" y="${y}" width="64" height="88" rx="5" fill="url(#dw-drum)"/>` +
  `<rect x="${x}" y="${y}" width="64" height="7" rx="3.5" fill="${ACCENT}"/>` +
  `<circle cx="${x + 18}" cy="${y + 3.5}" r="2" fill="${NAVY}" opacity="0.55"/>` +
  `<circle cx="${x + 46}" cy="${y + 3.5}" r="2" fill="${NAVY}" opacity="0.55"/>` +
  `<rect x="${x + 5}" y="${y + 13}" width="4" height="62" rx="2" fill="rgba(255,255,255,0.14)"/>` +
  `<rect x="${x - 2}" y="${y + 26}" width="68" height="5" rx="2.5" fill="${RIB}"/>` +
  `<rect x="${x - 2}" y="${y + 26}" width="68" height="1.5" rx="0.75" fill="rgba(255,255,255,0.16)"/>` +
  `<rect x="${x - 2}" y="${y + 58}" width="68" height="5" rx="2.5" fill="${RIB}"/>` +
  `<rect x="${x - 2}" y="${y + 58}" width="68" height="1.5" rx="0.75" fill="rgba(255,255,255,0.16)"/>` +
  `<rect x="${x + 16}" y="${y + 34}" width="32" height="20" rx="3" fill="#FFFFFF"/>` +
  `<path transform="translate(${x + 32} ${y + 41})" d="M0 -3.6C1.8 -1.3 2.9 0.2 2.9 1.5A2.9 2.9 0 1 1 -2.9 1.5C-2.9 0.2 -1.8 -1.3 0 -3.6Z" fill="#1B4F9C"/>` +
  `<text x="${x + 32}" y="${y + 50.5}" text-anchor="middle" fill="${NAVY}" font-size="4.6" style="font-family:var(--font-body);font-weight:600;letter-spacing:0.06em">APEX D.E.F</text>`;

// Warehouse shell: back wall, roof truss, wall seams, hanging lamp, floor.
const shell =
  `<rect x="10" y="44" width="500" height="302" fill="${NAVY}" opacity="0.5"/>` +
  `<path d="M135 96V346M260 96V346M385 96V346" stroke="rgba(255,255,255,0.05)" stroke-width="1.5"/>` +
  `<path d="M10 44H510" stroke="rgba(255,255,255,0.10)" stroke-width="1.5"/>` +
  `<path d="M10 90H510" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"/>` +
  `<path d="M10 44 72.5 90 135 44 197.5 90 260 44 322.5 90 385 44 447.5 90 510 44" fill="none" stroke="rgba(255,255,255,0.10)" stroke-width="1.5"/>` +
  `<path d="M300 90V128" stroke="${METAL}" stroke-width="1.5"/>` +
  `<path d="M290 128h20l5 10h-30Z" fill="${NAVY}" stroke="${METAL}" stroke-width="1.5" stroke-linejoin="round"/>` +
  `<circle cx="300" cy="142" r="11" fill="rgba(47,182,233,0.15)"/>` +
  `<circle cx="300" cy="142" r="3.5" fill="${ACCENT}"/>` +
  `<ellipse cx="260" cy="340" rx="250" ry="50" fill="url(#dw-glow)"/>` +
  `<path d="M10 346H510" stroke="rgba(255,255,255,0.14)" stroke-width="1.5"/>`;

// Floor shadows under the three object groups.
const shadows =
  '<ellipse cx="168" cy="347" rx="120" ry="5" fill="rgba(6,11,20,0.45)"/>' +
  '<ellipse cx="306" cy="347" rx="26" ry="3.5" fill="rgba(6,11,20,0.45)"/>' +
  '<ellipse cx="404" cy="347" rx="80" ry="5" fill="rgba(6,11,20,0.45)"/>';

// Pallet of five 210 L drums (3 + 2 stack).
const drumStack =
  `<rect x="54" y="326" width="228" height="6" rx="1.5" fill="${NAVY}" stroke="rgba(255,255,255,0.08)" stroke-width="1.5"/>` +
  `<path d="M58 332h16v14H58Zm102 0h16v14h-16Zm102 0h16v14h-16Z" fill="${NAVY}"/>` +
  drum(64, 238) +
  drum(136, 238) +
  drum(208, 238) +
  drum(100, 150) +
  drum(172, 150);

// Single 20 L bucket on the floor (PackVisual def-20l geometry, small).
const bucket =
  `<path d="M286 292C292 274 320 274 326 292" fill="none" stroke="${METAL}" stroke-width="1.5"/>` +
  `<circle cx="286" cy="292" r="2" fill="${METAL}"/><circle cx="326" cy="292" r="2" fill="${METAL}"/>` +
  `<path d="M284 299h44l-3.6 42q-0.5 5-5.5 5h-25.8q-5 0-5.5-5Z" fill="url(#dw-drum)"/>` +
  `<rect x="281" y="290" width="50" height="9" rx="4.5" fill="${ACCENT}"/>` +
  `<rect x="295" y="312" width="22" height="14" rx="3" fill="#FFFFFF"/>` +
  `<path transform="translate(306 319)" d="M0 -3C1.5 -1.1 2.4 0.2 2.4 1.3A2.4 2.4 0 1 1 -2.4 1.3C-2.4 0.2 -1.5 -1.1 0 -3Z" fill="#1B4F9C"/>`;

// 1000 L IBC tote: navy pallet, light bottle, galvanized cage, document label.
const ibc =
  `<rect x="336" y="330" width="150" height="6" rx="1.5" fill="${NAVY}" stroke="rgba(255,255,255,0.08)" stroke-width="1.5"/>` +
  `<path d="M340 336h14v10h-14Zm64 0h14v10h-14Zm64 0h14v10h-14Z" fill="${NAVY}"/>` +
  `<rect x="396" y="208" width="30" height="14" rx="3" fill="${ACCENT}"/>` +
  `<rect x="342" y="222" width="138" height="104" rx="8" fill="url(#dw-ibc)"/>` +
  `<rect x="348" y="230" width="5" height="88" rx="2.5" fill="rgba(255,255,255,0.5)"/>` +
  `<rect x="338" y="218" width="146" height="112" rx="4" fill="none" stroke="${METAL}" stroke-width="1.5"/>` +
  `<path d="M374.5 218v112M411 218v112M447.5 218v112M338 255.3h146M338 292.7h146" stroke="${METAL}" stroke-width="1.5"/>` +
  `<rect x="384" y="258" width="54" height="32" rx="4" fill="#FFFFFF" stroke="rgba(10,27,61,0.10)" stroke-width="1.5"/>` +
  `<path transform="translate(411 267)" d="M0 -3.6C1.8 -1.3 2.9 0.2 2.9 1.5A2.9 2.9 0 1 1 -2.9 1.5C-2.9 0.2 -1.8 -1.3 0 -3.6Z" fill="#1B4F9C"/>` +
  `<text x="411" y="279.5" text-anchor="middle" fill="${NAVY}" font-size="7" style="font-family:var(--font-display);font-weight:600;letter-spacing:0.02em">APEX D.E.F</text>` +
  `<text x="411" y="286.5" text-anchor="middle" fill="#5B6B7F" font-size="4.6" style="font-family:var(--font-body);font-weight:600;letter-spacing:0.1em">1000 L</text>`;

const scene = defs + shell + shadows + drumStack + bucket + ibc;
---

<svg
  class="dealer-hero-art"
  viewBox="0 0 520 368"
  role="img"
  aria-label="Illustration: palletised APEX D.E.F 210-litre drums, a 20-litre bucket and a 1000-litre IBC tote stacked in a dealer warehouse"
  set:html={scene}
/>

<style>
  .dealer-hero-art {
    width: 100%;
    height: auto;
  }
</style>
