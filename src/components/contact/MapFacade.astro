---
// Click-to-activate Google Maps facade — design.md §4.7 #map.
// No third-party iframe loads before the visitor asks for it. No-JS path:
// "Open map" is a plain external link to Google Maps; the component <script>
// upgrades it to inject the embed iframe in place. "Get Directions" always
// works without JS. Facade art is authored vector (1.5px strokes, brand
// palette) per DECISIONS.md #18 — plot-grid scene with a droplet-nosed pin.
import { site } from '../../data/site.js';

const q = encodeURIComponent(site.address.mapsQuery);
const embedSrc = `https://www.google.com/maps?q=${q}&output=embed`;
const viewUrl = `https://www.google.com/maps?q=${q}`;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${q}`;
const caption = `${site.legalLine} — ${site.address.mapsQuery}`;
const iframeTitle = `Map — ${caption}`;
---

<div class="map-card" data-map-facade data-map-src={embedSrc} data-map-title={iframeTitle}>
  <div class="map-stage" data-map-stage>
    <svg class="map-art" viewBox="0 0 800 480" preserveAspectRatio="xMidYMid slice" fill="none" aria-hidden="true">
      <rect width="800" height="480" fill="#F6F9FC"></rect>
      <!-- wide roads -->
      <g stroke="rgba(10,27,61,0.06)" stroke-width="22">
        <path d="M0 330H800"></path>
        <path d="M180 0V480"></path>
        <path d="M560 0L640 480"></path>
      </g>
      <!-- lane dashes -->
      <g stroke="rgba(10,27,61,0.14)" stroke-width="1.5" stroke-dasharray="10 12">
        <path d="M0 330H800"></path>
        <path d="M180 0V480"></path>
        <path d="M560 0L640 480"></path>
      </g>
      <!-- minor roads -->
      <g stroke="rgba(10,27,61,0.1)" stroke-width="1.5">
        <path d="M0 120H800"></path>
        <path d="M0 225H395"></path>
        <path d="M380 0V330"></path>
        <path d="M180 425H800"></path>
      </g>
      <!-- industrial blocks -->
      <g stroke="rgba(10,27,61,0.08)" stroke-width="1.5">
        <rect x="215" y="150" width="130" height="150" rx="6"></rect>
        <rect x="230" y="40" width="120" height="52" rx="6"></rect>
        <rect x="60" y="360" width="90" height="70" rx="6"></rect>
        <rect x="690" y="150" width="80" height="140" rx="6"></rect>
        <rect x="40" y="150" width="110" height="52" rx="6"></rect>
      </g>
      <!-- Plot No. 415 -->
      <rect x="410" y="150" width="130" height="150" rx="8" fill="rgba(47,182,233,0.12)" stroke="#1B4F9C" stroke-width="1.5"></rect>
      <!-- pulse rings -->
      <circle cx="475" cy="222" r="58" stroke="#2FB6E9" stroke-opacity="0.25" stroke-width="1.5"></circle>
      <circle cx="475" cy="222" r="88" stroke="#2FB6E9" stroke-opacity="0.12" stroke-width="1.5"></circle>
      <!-- pin -->
      <ellipse cx="475" cy="262" rx="16" ry="4.5" fill="rgba(47,182,233,0.35)"></ellipse>
      <path d="M475 178c-19 0-34 14.6-34 33 0 24 34 51 34 51s34-27 34-51c0-18.4-15-33-34-33Z" fill="#1B4F9C"></path>
      <circle cx="475" cy="211" r="12" fill="#F6F9FC"></circle>
      <circle cx="475" cy="211" r="5" fill="#2FB6E9"></circle>
    </svg>
    <div class="map-overlay">
      <a class="btn btn--primary-light" href={viewUrl} target="_blank" rel="noopener" data-map-open>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
        Open map
      </a>
    </div>
  </div>
  <div class="map-meta">
    <p class="map-caption">{caption}</p>
    <a class="btn btn--secondary-light" href={directionsUrl} target="_blank" rel="noopener">
      Get Directions
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"/></svg>
    </a>
  </div>
</div>

<style>
  .map-card {
    background: #fff;
    border: 1px solid var(--hairline-light);
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: var(--e-1);
  }
  .map-stage {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #f6f9fc;
  }
  @media (min-width: 768px) {
    .map-stage {
      aspect-ratio: 21 / 9;
    }
  }
  .map-art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .map-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
  }
  .map-overlay .btn {
    pointer-events: auto;
    box-shadow: var(--e-3);
  }
  .map-stage :global(iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .map-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-5) clamp(16px, 3vw, 32px);
    border-top: 1px solid var(--hairline-light);
  }
  .map-caption {
    color: var(--slate-500);
    font-size: var(--fs-small);
    max-width: 52ch;
  }
</style>

<script>
  document.querySelectorAll('[data-map-facade]').forEach((facade) => {
    const trigger = facade.querySelector('[data-map-open]');
    const stage = facade.querySelector('[data-map-stage]');
    if (!trigger || !stage) return;
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      if (stage.querySelector('iframe')) return;
      const iframe = document.createElement('iframe');
      iframe.src = facade.getAttribute('data-map-src') || '';
      iframe.title = facade.getAttribute('data-map-title') || 'Map';
      iframe.loading = 'lazy';
      iframe.referrerPolicy = 'no-referrer-when-downgrade';
      iframe.setAttribute('allowfullscreen', '');
      stage.replaceChildren(iframe);
      facade.classList.add('is-active');
      iframe.addEventListener('load', () => iframe.focus({ preventScroll: true }), { once: true });
    });
  });
</script>
