---
// #agriculture chapter scene (design.md §4.4 / DECISIONS.md #18): authored vector
// tractor-in-field silhouette at golden hour — brand palette, 1.5px strokes,
// PackVisual gradient language. Drawn at 16:7; preserveAspectRatio slice crops
// to 16:10 on mobile (key content kept within x 120–680).
---

<svg
  class="scene-svg"
  viewBox="0 0 800 350"
  preserveAspectRatio="xMidYMid slice"
  role="img"
  aria-label="Illustration: TREM IV tractor with a dedicated DEF tank working a field at golden hour"
>
  <defs>
    <linearGradient id="ag-sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#060B14"></stop>
      <stop offset="0.6" stop-color="#0A1B3D"></stop>
      <stop offset="1" stop-color="#16407E"></stop>
    </linearGradient>
    <linearGradient id="ag-glow" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#F5A524" stop-opacity="0"></stop>
      <stop offset="1" stop-color="#F5A524" stop-opacity="0.2"></stop>
    </linearGradient>
    <linearGradient id="ag-field" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#0B1B33"></stop>
      <stop offset="1" stop-color="#060B14"></stop>
    </linearGradient>
    <linearGradient id="ag-tractor" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#1B4F9C"></stop>
      <stop offset="1" stop-color="#0A1B3D"></stop>
    </linearGradient>
  </defs>

  <!-- sky, sun, horizon glow -->
  <rect x="0" y="0" width="800" height="244" fill="url(#ag-sky)"></rect>
  <circle cx="596" cy="200" r="24" fill="#F5A524" opacity="0.35"></circle>
  <circle cx="596" cy="200" r="40" fill="none" stroke="#F5A524" stroke-width="1.5" opacity="0.18"></circle>
  <circle cx="596" cy="200" r="58" fill="none" stroke="#F5A524" stroke-width="1.5" opacity="0.08"></circle>
  <rect x="0" y="150" width="800" height="94" fill="url(#ag-glow)"></rect>

  <!-- birds -->
  <path d="M200 92q6-8 12 0M222 84q5-7 10 0" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" stroke-linecap="round"></path>

  <!-- distant treeline + field -->
  <path d="M0 244C120 228 240 238 360 233C480 228 640 240 800 234L800 244Z" fill="#0A1B3D" opacity="0.85"></path>
  <rect x="0" y="244" width="800" height="106" fill="url(#ag-field)"></rect>
  <path d="M0 244h800" stroke="rgba(255,255,255,0.16)" stroke-width="1.5"></path>

  <!-- crop rows converging to the horizon -->
  <g stroke="rgba(31,157,85,0.3)" stroke-width="1.5" stroke-linecap="round">
    <path d="M60 350L280 246"></path>
    <path d="M170 350L305 246"></path>
    <path d="M280 350L330 246"></path>
    <path d="M640 350L470 246"></path>
    <path d="M735 350L505 246"></path>
  </g>
  <g stroke="#1F9D55" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.7">
    <path d="M140 330c3-8 8-12 12-13"></path>
    <path d="M154 332c2-6 6-10 11-12"></path>
    <path d="M126 334c1-6 4-10 8-12"></path>
  </g>

  <!-- implement: disc harrow trailing the tractor -->
  <path d="M498 256l12 4" stroke="#8FA3B8" stroke-width="1.5" stroke-linecap="round"></path>
  <path d="M508 260h66" stroke="#8FA3B8" stroke-width="1.5" stroke-linecap="round"></path>
  <path d="M522 260v10M548 260v10M570 260v10" stroke="#8FA3B8" stroke-width="1.5"></path>
  <circle cx="522" cy="282" r="13" fill="#0A1B3D" stroke="#8FA3B8" stroke-width="1.5"></circle>
  <circle cx="548" cy="282" r="13" fill="#0A1B3D" stroke="#8FA3B8" stroke-width="1.5"></circle>
  <circle cx="570" cy="282" r="13" fill="#0A1B3D" stroke="#8FA3B8" stroke-width="1.5"></circle>
  <path d="M586 292l10 4M580 296l6 6" stroke="rgba(255,255,255,0.12)" stroke-width="1.5" stroke-linecap="round"></path>

  <!-- tractor, facing left -->
  <rect x="356" y="202" width="6" height="26" rx="3" fill="#0A1B3D" stroke="rgba(255,255,255,0.16)" stroke-width="1.5"></rect>
  <rect x="344" y="250" width="148" height="16" rx="4" fill="#0A1B3D"></rect>
  <rect x="340" y="226" width="78" height="28" rx="8" fill="url(#ag-tractor)" stroke="rgba(255,255,255,0.16)" stroke-width="1.5"></rect>
  <path d="M346 233v14" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round"></path>
  <rect x="418" y="186" width="62" height="68" rx="8" fill="url(#ag-tractor)" stroke="rgba(255,255,255,0.16)" stroke-width="1.5"></rect>
  <rect x="426" y="194" width="44" height="30" rx="4" fill="rgba(47,182,233,0.14)" stroke="rgba(47,182,233,0.45)" stroke-width="1.5"></rect>
  <!-- DEF tank with its blue cap -->
  <rect x="400" y="238" width="24" height="15" rx="4" fill="#0A1B3D" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"></rect>
  <circle cx="412" cy="236" r="4.5" fill="#2FB6E9"></circle>
  <!-- wheels -->
  <circle cx="464" cy="264" r="32" fill="#0A1B3D" stroke="#8FA3B8" stroke-width="1.5"></circle>
  <circle cx="464" cy="264" r="6" fill="#8FA3B8"></circle>
  <circle cx="464" cy="264" r="19" fill="none" stroke="rgba(143,163,184,0.4)" stroke-width="1.5"></circle>
  <circle cx="362" cy="279" r="17" fill="#0A1B3D" stroke="#8FA3B8" stroke-width="1.5"></circle>
  <circle cx="362" cy="279" r="4" fill="#8FA3B8"></circle>

  <!-- foreground leaf accent -->
  <path
    d="M620 330C633 312 652 303 668 303C666 322 652 336 630 338C625 338 621 335 620 330Z"
    fill="rgba(31,157,85,0.16)"
    stroke="#1F9D55"
    stroke-width="1.5"
    stroke-linejoin="round"></path>
  <path d="M626 334C638 324 652 314 664 308" fill="none" stroke="#1F9D55" stroke-width="1.5" stroke-linecap="round"></path>
</svg>

<style>
  .scene-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
