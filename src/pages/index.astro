---
// Home — content.md §3.1 (copy verbatim), design.md §4.1 (layout/backgrounds/motion).
// Static-first build: complete, readable and convertible with JS disabled.
// Contracts for the later signature motion pass:
//   - data-reveal + --reveal-delay   → global IO entrance system (app.js)
//   - data-counter="N"               → global counter system (app.js), numerals only
//   - data-rail                     → #products scroll-snap rail (later desktop pin/scrub)
//   - data-nox-loop                 → #how-it-works particle loop (pure CSS today)
//   - data-marquee + .marquee-track → #marquee pure-CSS loop; motion.js drives
//                                     --marquee-rate / skew on the full tier
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Faq from '../components/Faq.astro';
import PackVisual from '../components/PackVisual.astro';
import HeroScene from '../components/HeroScene.astro';
import AppScene from '../components/home/AppScene.astro';
import NoxLoop from '../components/home/NoxLoop.astro';
import { site, skus, waLink } from '../data/site.js';
import { graph, organization, webSite } from '../utils/schema.js';

const primaryPhone = site.phones.find((p) => p.primary) ?? site.phones[0];
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.address.mapsQuery)}`;
const bisFootnote =
  'Manufactured to IS 17042 (Part 1); BIS licence details will be displayed on grant.';

/* ---------- Shared inline icons (Lucide-style 1.5px strokes, §2.5) ---------- */
const phoneIcon =
  '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>';
const whatsappIcon =
  '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.7.8-.8 1-.2.2-.3.2-.6.1a6.7 6.7 0 0 1-3.3-2.9c-.3-.4 0-.5.1-.7l.5-.6c.1-.2.1-.3.2-.5s0-.4 0-.5c0-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3a3 3 0 0 0-1 2.2c0 1.3 1 2.6 1.1 2.8.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.2-.2-.5-.3z"/></svg>';
const mapPinIcon =
  '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>';
const copyIcon =
  '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
// Custom hexagon-badge-with-check (cert chips, §2.5 custom icon set).
const sealIcon =
  '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l8 4.6v9.2L12 22l-8-6.2V6.6Z" opacity="0.55"/><path d="M8.6 12.2l2.4 2.4 4.4-5"/></svg>';

/* ---------- Motif partials (§2.6) ---------- */
const hexCluster = (id: string) =>
  `<svg viewBox="0 0 360 290" fill="none" aria-hidden="true"><defs><path id="${id}" d="M50 0l43.3 25v50L50 100 6.7 75V25Z"/></defs><g stroke="#FFFFFF" stroke-width="1.5"><use href="#${id}" x="60" y="10"/><use href="#${id}" x="160" y="66"/><use href="#${id}" x="60" y="122"/><use href="#${id}" x="160" y="178"/><use href="#${id}" x="260" y="122"/></g></svg>`;
const liquidLine = (id: string) =>
  `<svg viewBox="0 0 1440 240" preserveAspectRatio="none" fill="none" aria-hidden="true"><defs><linearGradient id="${id}" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="#2FB6E9" stop-opacity="0"/><stop offset="0.5" stop-color="#2FB6E9" stop-opacity="0.6"/><stop offset="1" stop-color="#2FB6E9" stop-opacity="0"/></linearGradient></defs><path d="M0 140C180 60 420 200 720 130S1200 40 1440 120" stroke="url(#${id})" stroke-width="2"/></svg>`;
const marqueeDrop =
  '<svg width="10" height="14" viewBox="0 0 22 28" fill="none" aria-hidden="true"><path d="M11 2C11 2 20 12.4 20 18.6A9 9 0 0 1 2 18.6C2 12.4 11 2 11 2Z" fill="rgba(47,182,233,0.45)"/></svg>';

/* ---------- Phosphor-Duotone-style USP icons (back layer def-tint, front 1.5px blue-600) ---------- */
const TINT = 'rgba(47,182,233,0.12)';
const STROKE = '#1B4F9C';
const duo = (back: string, front: string) =>
  `<svg width="36" height="36" viewBox="0 0 32 32" fill="none" aria-hidden="true">${back}` +
  `<g stroke="${STROKE}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none">${front}</g></svg>`;

const uspIcons: Record<string, string> = {
  factory: duo(
    `<path d="M5 13.5l7 4.5v-4.5l7 4.5v-4.5l8 4.5V27H5Z" fill="${TINT}"/>`,
    '<path d="M5 27V13.5l7 4.5v-4.5l7 4.5v-4.5l8 4.5V27"/><path d="M3.5 27h25"/><path d="M9 22.5h2M15 22.5h2M21 22.5h2"/><path d="M7 13.5V6h3v7"/>'
  ),
  flask: duo(
    `<path d="M14 12l-7 11.5a2.5 2.5 0 0 0 2.1 4h13.8a2.5 2.5 0 0 0 2.1-4L18 12V6h-4Z" fill="${TINT}"/>`,
    '<path d="M12.5 4.5h7"/><path d="M14 4.5V12l-7 11.5a2.5 2.5 0 0 0 2.1 4h13.8a2.5 2.5 0 0 0 2.1-4L18 12V4.5"/><path d="M10.5 20.5h11"/><circle cx="13.5" cy="24" r="0.5"/><circle cx="17.5" cy="23" r="0.5"/>'
  ),
  truck: duo(
    `<rect x="4" y="9" width="15" height="12" rx="1.5" fill="${TINT}"/>`,
    '<rect x="4" y="9" width="15" height="12" rx="1.5"/><path d="M19 13h4.6L28 17.6V21h-9"/><circle cx="10.5" cy="23.5" r="2.75"/><circle cx="22.5" cy="23.5" r="2.75"/>'
  ),
  handshake: duo(
    `<path d="M16 11l6 5-6 5.5-6-5.5Z" fill="${TINT}"/>`,
    '<path d="M2.5 10.5h5L16 18M29.5 10.5h-5l-4 3.4"/><path d="M16 18l2.4 2.2a2 2 0 0 0 2.8-2.9L16.6 13a3.2 3.2 0 0 0-4.4.1l-2.7 2.6"/><path d="M13.5 21.5l1.6 1.5a1.9 1.9 0 0 0 2.7-2.7"/><path d="M10.5 19.2l1.9 1.8a1.9 1.9 0 0 1-2.7 2.7l-2.2-2.1"/>'
  ),
};

/* ---------- Section data (copy verbatim, content.md §3.1) ---------- */
const stats = [
  { value: '18', unit: '', label: 'parameters in our published ISO 22241-1 spec — the full table, in the open' },
  { value: '6', unit: '', label: 'pack sizes, from a 5 L can to tanker supply' },
  { value: '48', unit: 'h', label: 'doorstep delivery — most orders same-day or next-day' },
  { value: '100', unit: '%', label: 'of batches cleared by refractometer and density checks before dispatch' },
];

const appTiles = [
  {
    id: 'agriculture',
    title: 'Agriculture',
    line: 'TREM IV tractors above 50 HP and combine harvesters. Our first market, still our biggest.',
    chip: 'Since Jan 2023',
    wide: true,
  },
  {
    id: 'transport',
    title: 'Transport',
    line: 'BS-VI trucks and buses that derate without DEF. Keep the fleet at full torque.',
    chip: 'Since Apr 2020',
    wide: false,
  },
  {
    id: 'construction',
    title: 'Construction & Mining',
    line: 'CEV IV machines from backhoes to excavators.',
    chip: 'Since Oct 2021',
    wide: false,
  },
  {
    id: 'gensets',
    title: 'Gensets',
    line: 'CPCB IV+ DG sets up to 800 kW now run SCR — and monitor DEF usage.',
    chip: 'Since Jul 2023',
    wide: true,
  },
] as const;

const usps = [
  {
    icon: 'factory',
    title: 'Fresh-batch manufacturing',
    body: "Made to order in Bulandshahr, not warehoused for months. DEF degrades with age and heat; ours doesn't get the chance.",
  },
  {
    icon: 'flask',
    title: 'Lab-tested, every batch',
    body: 'Refractometer and density QC clear every batch against the ISO 22241-1 window before a single can is filled. COA on request with every supply.',
  },
  {
    icon: 'truck',
    title: '48-hour delivery, emergency dispatch',
    body: 'Most orders reach your gate same-day or next-day; 48 hours at the outside. Fleet running dry on a Sunday? Call — flexible scheduling and emergency dispatch for regular customers.',
  },
  {
    icon: 'handshake',
    title: 'Dealer & fleet support',
    body: 'Territory support, fluid-management help for regular buyers, and straight answers on the phone.',
  },
];

const specPeekRows = [
  { param: 'Urea content', value: '31.8–33.2%' },
  { param: 'Density @20 °C', value: '1.0870–1.0930 g/cm³' },
  { param: 'Refractive index @20 °C', value: '1.3814–1.3843' },
  { param: 'Biuret', value: '≤0.3%' },
];

const marqueeChips = [
  'ISO 22241-1',
  'IS 17042 (Part 1)',
  'AUS 32',
  '32.5% urea · 67.5% demin water',
  'Lab-tested every batch',
  'COA with every supply',
  'Batch + expiry printed on every pack',
  'Made in Bulandshahr, UP',
];

const faqs = [
  {
    q: 'What is DEF and does my vehicle need it?',
    a: 'DEF (Diesel Exhaust Fluid, also called AUS 32) is a 32.5% urea solution injected into the exhaust of SCR-equipped diesels. If your vehicle is a BS-VI truck/bus/car, a TREM IV tractor above 50 HP, a CEV IV machine or a CPCB IV+ genset — it needs DEF to run legally and at full power.',
  },
  {
    q: 'How much DEF will I use?',
    a: 'Typically 3–6% of your diesel consumption — about 5 litres of DEF per 100 litres of diesel for a BS-VI truck. High-load agricultural duty runs at the upper end.',
  },
  {
    q: 'What happens if I run out?',
    a: "BS-VI vehicles warn, then derate — power and speed are cut by the ECU until you refill. Don't test it; keep a can in the cab.",
  },
  {
    q: 'How long does DEF last in storage?',
    a: '12–18 months under proper Indian storage — sealed pack, under 30 °C, away from sunlight. Every APEX pack carries its manufacture and expiry date.',
  },
  {
    q: 'How do I buy APEX D.E.F?',
    a: `Call or WhatsApp ${primaryPhone.display}, tell us your pack size and location, and we arrange doorstep delivery. No minimums that don't make sense — from a single 5 L can via our dealers to full tanker loads.`,
  },
];

const schema = graph(organization(), webSite());
---

<BaseLayout
  title="APEX D.E.F | DEF (Diesel Exhaust Fluid) Manufacturer India"
  description="ISO 22241 / IS 17042 Diesel Exhaust Fluid made in Bulandshahr, UP. Packs from 5 L to bulk tanker. Lab-tested every batch. Call or WhatsApp APEX D.E.F."
  ogTitle="APEX D.E.F — Diesel Exhaust Fluid, made to the numbers."
  ogDescription="32.5% urea. 67.5% demin water. Zero shortcuts. Lab-tested DEF from Bulandshahr for tractors, trucks, machines and gensets."
  path="/"
  schema={schema}
>
  <!-- ================= #hero — cinematic dark stage ================= -->
  <section id="hero" class="section--dark hero">
    <div class="hero-hex" set:html={hexCluster('hx-hero')} />
    <div class="container container--max hero-grid">
      <div class="hero-copy">
        <p class="chip chip--dark" data-reveal>DEF · AUS 32 · Made in India</p>
        <h1 class="display-1" data-reveal style="--reveal-delay:1">
          32.5% urea. 67.5% demin water.<br /><span class="grad-text">Zero shortcuts.</span>
        </h1>
        <p class="lead muted hero-sub" data-reveal style="--reveal-delay:2">
          APEX D.E.F manufactures ISO 22241 / IS 17042-grade Diesel Exhaust Fluid in Bulandshahr,
          Uttar Pradesh — for tractors, trucks, construction machines and gensets across India.
        </p>
        <div class="hero-ctas" data-reveal style="--reveal-delay:3">
          <a class="btn btn--primary-dark" href={`tel:${primaryPhone.tel}`}>
            <span class="btn-ic" set:html={phoneIcon} /> Call Now
          </a>
          <a class="btn btn--secondary-dark" href="/products">Explore Products</a>
        </div>
        <ul class="cert-chips" role="list" data-reveal style="--reveal-delay:4">
          <li class="chip chip--dark"><span class="chip-ic" set:html={sealIcon} /> ISO 22241-1</li>
          <li class="chip chip--dark"><span class="chip-ic" set:html={sealIcon} /> IS 17042 (Part 1)</li>
          <li class="chip chip--dark"><span class="chip-ic" set:html={sealIcon} /> BIS*</li>
        </ul>
        <p class="cert-note" data-reveal style="--reveal-delay:5">*&nbsp;{bisFootnote}</p>
      </div>
      <div class="hero-visual" data-reveal style="--reveal-delay:2">
        <HeroScene />
      </div>
    </div>
    <a class="scroll-cue" href="#intro">
      <svg width="16" height="20" viewBox="0 0 22 28" fill="none" aria-hidden="true">
        <defs>
          <clipPath id="cue-clip">
            <path d="M11 2C11 2 20 12.4 20 18.6A9 9 0 0 1 2 18.6C2 12.4 11 2 11 2Z"></path>
          </clipPath>
        </defs>
        <g clip-path="url(#cue-clip)">
          <rect class="cue-fill" x="0" y="0" width="22" height="28" fill="rgba(47,182,233,0.55)"></rect>
        </g>
        <path d="M11 2C11 2 20 12.4 20 18.6A9 9 0 0 1 2 18.6C2 12.4 11 2 11 2Z" stroke="#2FB6E9" stroke-width="1.5"></path>
      </svg>
      <span class="overline">Scroll</span>
    </a>
    <div class="seam-liquid hero-seam" aria-hidden="true"></div>
  </section>

  <!-- ================= #intro — brand strip ================= -->
  <section id="intro" class="section--light" aria-labelledby="intro-h">
    <div class="container intro-wrap">
      <SectionHeader
        overline="What is APEX D.E.F"
        heading='<span class="grad-text">Agriculture first.</span> Every SCR engine after.'
        align="center"
        id="intro-h"
      />
      <p class="intro-body" data-reveal style="--reveal-delay:2">
        APEX D.E.F is the Diesel Exhaust Fluid brand of Apex Environment Solutions — built in
        Bulandshahr for India's fields first. TREM IV made DEF a daily input for every new tractor
        above 50 HP; we made it as easy to buy as diesel. The same fluid runs BS-VI trucks and
        buses, CEV IV construction machines and CPCB IV+ gensets. One spec. Six pack sizes. A phone
        call away.
      </p>
      <div class="intro-foot" data-reveal style="--reveal-delay:3">
        <span class="chip chip--leaf">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 4c0 10-6 16-14 16C6 10 12 4 20 4Z"/><path d="M6 20c2.5-5.5 6.5-9.5 11-12"/></svg>
          Apex Environment Solutions
        </span>
        <a class="btn btn--link" href="/about">Know the company →</a>
      </div>
    </div>
  </section>

  <!-- ================= #stats — counter band ================= -->
  <section id="stats" class="stats-band" aria-label="APEX D.E.F in numbers">
    <div class="stats-line" set:html={liquidLine('stats-liquid')} />
    <div class="container container--max">
      <div class="stats-grid">
        {stats.map((s, i) => (
          <div class="stat-cell" data-reveal style={`--reveal-delay:${i}`}>
            <p class="stat-num">
              <span class="tnum" data-counter={s.value}>{s.value}</span>
              {s.unit && <span class="stat-unit">{s.unit}</span>}
            </p>
            <p class="stat-label overline">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= #products — pack rail ================= -->
  <section id="products" class="section--light hairline-top-light cv-auto" aria-labelledby="products-h">
    <div class="container">
      <div class="products-head">
        <SectionHeader
          overline="Product Range"
          heading="One fluid. Six packs. Every duty cycle."
          lead="The fluid never changes — every pack carries the same ISO 22241 / IS 17042 spec. Pick the size that matches how you run."
          id="products-h"
        />
        <a class="btn btn--link rail-cta" href="/products" data-reveal>See all packs &amp; full spec →</a>
      </div>
    </div>
    <div class="rail-wrap">
      <div class="rail container" data-rail role="list">
        {skus.map((sku, i) => (
          <div class="card-light rail-card" role="listitem" data-reveal style={`--reveal-delay:${Math.min(i, 4)}`}>
            <div class="rail-media" style={`view-transition-name: sku-${sku.id}`}>
              <PackVisual sku={sku.id} size="68%" />
            </div>
            <h3 class="h4">
              <a class="rail-card-link" href={`/products#${sku.id}`}>{sku.pack}</a>
            </h3>
            <p class="small muted rail-line">{sku.oneLiner}</p>
            <a class="btn btn--secondary-light rail-call" href={`tel:${primaryPhone.tel}`}>
              <span class="btn-ic" set:html={phoneIcon} /> Call for Price
            </a>
          </div>
        ))}
      </div>
      <div class="rail-fade rail-fade--left" aria-hidden="true"></div>
      <div class="rail-fade rail-fade--right" aria-hidden="true"></div>
    </div>
    <div class="rail-dots" data-rail-dots aria-label="Product packs" hidden></div>
  </section>

  <!-- ================= #applications — 4-segment teaser ================= -->
  <section id="applications" class="section--dark cv-auto" aria-labelledby="apps-h">
    <div class="container">
      <SectionHeader overline="Applications" heading="Wherever diesel works, DEF works." id="apps-h" />
      <div class="apps-grid">
        {appTiles.map((t, i) => (
          <a
            class:list={['app-card', { 'is-wide': t.wide }]}
            href={`/applications#${t.id}`}
            data-reveal
            style={`--reveal-delay:${i}`}
          >
            <div class="app-art"><AppScene scene={t.id} /></div>
            <div class="app-scrim" aria-hidden="true"></div>
            <span class="app-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
            <div class="app-content">
              <h3>{t.title}</h3>
              <p class="small app-line">{t.line}</p>
              <span class="chip chip--dark tnum">{t.chip}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="apps-cta" data-reveal>
        <a class="btn btn--link" href="/applications">Find your segment →</a>
      </div>
    </div>
  </section>

  <!-- ================= #how-it-works — SCR teaser ================= -->
  <section id="how-it-works" class="section--dark hairline-top-dark cv-auto" aria-labelledby="hiw-h">
    <div class="hiw-hex" set:html={hexCluster('hx-hiw')} />
    <div class="container hiw-grid">
      <div class="hiw-copy">
        <p class="overline" data-reveal>The Science</p>
        <h2 class="display-2" id="hiw-h" data-reveal style="--reveal-delay:1">
          NOx goes in. Nitrogen and water come out.
        </h2>
        <p class="muted" data-reveal style="--reveal-delay:2">
          Inside every SCR system, DEF turns harmful nitrogen oxides into the same nitrogen and
          water vapour that make up clean air. Scroll through the full pipeline — from injection to
          catalyst — in 60 seconds.
        </p>
        <a class="btn btn--link" href="/what-is-def#scr" data-reveal style="--reveal-delay:3">Learn How SCR Works</a>
      </div>
      <div class="hiw-panel" data-reveal style="--reveal-delay:2">
        <NoxLoop />
        <p class="small hiw-caption">
          Red NOx particles meet DEF droplets and leave the tailpipe as N₂ + H₂O.
        </p>
      </div>
    </div>
  </section>

  <!-- ================= #why-apex — USP grid ================= -->
  <section id="why-apex" class="section--light cv-auto" aria-labelledby="why-h">
    <div class="container">
      <SectionHeader overline="Why APEX" heading="Every batch lab-tested. Every litre traceable." id="why-h" />
      <ul class="usp-grid" role="list">
        {usps.map((u, i) => (
          <li class="card-light usp-card" data-reveal style={`--reveal-delay:${i}`}>
            <span class="usp-icon" set:html={uspIcons[u.icon]} />
            <h3 class="h4">{u.title}</h3>
            <p class="small muted">{u.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ================= #quality — quality & compliance band ================= -->
  <section id="quality" class="section--dark cv-auto" aria-labelledby="quality-h">
    <div class="quality-hex" set:html={hexCluster('hx-quality')} />
    <div class="container quality-grid">
      <div class="quality-copy">
        <p class="overline" data-reveal>Quality &amp; Compliance</p>
        <h2 class="display-2" id="quality-h" data-reveal style="--reveal-delay:1">
          We publish our spec. Ask others for theirs.
        </h2>
        <p class="muted" data-reveal style="--reveal-delay:2">
          Most DEF sellers claim ISO 22241. We print the table — urea 31.8–33.2%, density
          1.0870–1.0930 g/cm³ at 20 °C, metals held to fractions of a ppm — and our own lab clears
          every batch against it before dispatch, with full-specification analysis on a defined
          cadence.
        </p>
        <ul class="cert-chips" role="list" data-reveal style="--reveal-delay:3">
          <li class="chip chip--dark">ISO 22241-1</li>
          <li class="chip chip--dark">IS 17042 (Part 1)</li>
          <li class="chip chip--dark">BIS*</li>
        </ul>
        <p class="cert-note" data-reveal style="--reveal-delay:4">*&nbsp;{bisFootnote}</p>
