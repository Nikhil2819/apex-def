---
// Contact page — content.md §3.7 (copy verbatim), design.md §4.7 (layout/motion).
// Static-first build: complete, readable and convertible with JS disabled
// (tel:/wa.me/mailto links, native form POST, Get Directions plain link).
// Progressive enhancements + motion-layer contracts:
//   - data-reveal + --reveal-delay  → global IO entrance system (app.js)
//   - [data-copy]                   → click-to-copy phones (app.js adds .is-copied, 1.5s chip)
//   - data-map-facade / data-map-open / data-map-stage / data-map-src
//                                   → click-to-activate Google Maps embed (MapFacade.astro;
//                                     no iframe loads before click, no-JS = external link)
//   - data-anim="liquid-line"       → #form background line dash-offset scrub (later phase)
import BaseLayout from '../layouts/BaseLayout.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import MapFacade from '../components/contact/MapFacade.astro';
import { site, waLink } from '../data/site.js';
import { graph, breadcrumbs } from '../utils/schema.js';

const primaryPhone = site.phones.find((p) => p.primary) ?? site.phones[0];
const waHref = waLink();
const hoursDelay = site.showEmails ? 6 : 5;

// Lucide-style 1.5px stroke icons (design.md §2.5) + mono-stroke WhatsApp glyph.
const iconPhone =
  '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>';
const iconWa =
  '<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.7.8-.8 1-.2.2-.3.2-.6.1a6.7 6.7 0 0 1-3.3-2.9c-.3-.4 0-.5.1-.7l.5-.6c.1-.2.1-.3.2-.5s0-.4 0-.5c0-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3a3 3 0 0 0-1 2.2c0 1.3 1 2.6 1.1 2.8.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.2-.2-.5-.3z"/></svg>';
const iconMail =
  '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 8 9 6 9-6"/></svg>';
const iconClock =
  '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg>';
const iconCopy =
  '<svg class="icon-copy" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
const iconCheck =
  '<svg class="icon-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12.5 4.5 4.5L19 7.5"/></svg>';

const schema = graph(
  breadcrumbs([
    { name: 'Home', path: '/' },
    { name: 'Contact', path: '/contact' },
  ]),
  {
    '@type': 'ContactPage',
    '@id': `${site.domain}/contact#page`,
    url: `${site.domain}/contact`,
    name: 'Contact APEX D.E.F',
    about: { '@id': `${site.domain}/#org` },
    openingHours: 'Mo-Sa 09:00-18:00',
  }
);
---

<BaseLayout
  title="Contact APEX D.E.F | Call, WhatsApp or Enquire"
  description="Call +91 84495 07181, WhatsApp, or send an enquiry. APEX D.E.F, Plot No. 415, Industrial Area, Bulandshahr, UP 203001. GSTIN 09BJNPN5877K1Z7."
  ogTitle="Talk to a person, not a portal."
  ogDescription="Call or WhatsApp +91 84495 07181 for DEF supply, dealership or bulk enquiries. Bulandshahr, UP."
  path="/contact"
  schema={schema}
  headerTheme="light"
>
  <!-- #reach — light page-hero: H1 + intro + contact cards -->
  <section id="reach" class="section--light reach-hero">
    <div class="container">
      <p class="overline" data-reveal>Contact</p>
      <h1 class="display-2 reach-title" data-reveal style="--reveal-delay:1">Reach APEX D.E.F.</h1>
      <p class="lead muted reach-intro" data-reveal style="--reveal-delay:2">
        For orders, dealership, bulk supply or a technical question — the fastest route is a call
        or WhatsApp. Forms are answered within one working day.
      </p>

      <ul class="reach-grid" role="list">
        <!-- Call card -->
        <li class="card-light reach-card" data-reveal style="--reveal-delay:3">
          <span class="card-icon" set:html={iconPhone} />
          <h2 class="h4 card-title">Call</h2>
          <p class="overline card-label">Sales &amp; orders</p>
          <div class="phone-list">
            {site.phones.map((p) => (
              <div class="phone-row">
                <a class="phone-link tnum" href={`tel:${p.tel}`}>{p.display}</a>
                <button class="copy-btn" type="button" data-copy={p.display} aria-label={`Copy ${p.display}`}>
                  <span class="ic" set:html={iconCopy + iconCheck} />
                  <span class="copy-chip" aria-hidden="true">Copied</span>
                </button>
              </div>
            ))}
          </div>
        </li>

        <!-- WhatsApp card -->
        <li class="card-light reach-card" data-reveal style="--reveal-delay:4">
          <span class="card-icon" set:html={iconWa} />
          <h2 class="h4 card-title">WhatsApp</h2>
          <a class="btn btn--whatsapp" href={waHref} target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.7.8-.8 1-.2.2-.3.2-.6.1a6.7 6.7 0 0 1-3.3-2.9c-.3-.4 0-.5.1-.7l.5-.6c.1-.2.1-.3.2-.5s0-.4 0-.5c0-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3a3 3 0 0 0-1 2.2c0 1.3 1 2.6 1.1 2.8.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.2-.2-.5-.3z"/></svg>
            WhatsApp Us
          </a>
          <p class="small muted wa-note">
            Opens with a prefilled message — “Hi APEX D.E.F, I want to enquire about DEF supply.
            Name: / City: / Pack size:”
          </p>
        </li>

        <!-- Email card — flag-gated OFF until mailboxes are live (DECISIONS.md #20) -->
        {site.showEmails && (
          <li class="card-light reach-card" data-reveal style="--reveal-delay:5">
            <span class="card-icon" set:html={iconMail} />
            <h2 class="h4 card-title">Email</h2>
            <ul class="email-list" role="list">
              {site.emails.map((e) => (
                <li>
                  <a href={`mailto:${e.address}`}>{e.address}</a>
                  <span class="small muted">({e.label})</span>
                </li>
              ))}
            </ul>
          </li>
        )}

        <!-- Hours card -->
        <li class="card-light reach-card" data-reveal style={`--reveal-delay:${hoursDelay}`}>
          <span class="card-icon" set:html={iconClock} />
          <h2 class="h4 card-title">Hours</h2>
          <p class="hours-line tnum">{site.hours}</p>
          <p class="small muted">
            Fleet running dry on a Sunday? Call — flexible scheduling and emergency dispatch for
            regular customers.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <!-- #form — dark split: expectations copy + enquiry form (white card) -->
  <section id="form" class="section--dark form-sec cv-auto" aria-labelledby="form-h">
    <div class="form-line" aria-hidden="true">
      <svg viewBox="0 0 1440 320" preserveAspectRatio="none" data-anim="liquid-line">
        <defs>
          <linearGradient id="ct-line" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0" stop-color="#2FB6E9" stop-opacity="0"></stop>
            <stop offset="0.5" stop-color="#2FB6E9" stop-opacity="0.55"></stop>
            <stop offset="1" stop-color="#2FB6E9" stop-opacity="0"></stop>
          </linearGradient>
        </defs>
        <path d="M0 160C240 80 480 240 760 170S1200 60 1440 150" fill="none" stroke="url(#ct-line)" stroke-width="2"></path>
      </svg>
    </div>
    <div class="container form-split">
      <div class="form-head">
        <h2 id="form-h" class="display-2" data-reveal>Send an enquiry.</h2>
      </div>
      <div class="form-col" data-reveal style="--reveal-delay:2">
        <EnquiryForm />
      </div>
      <div class="form-expect" data-reveal style="--reveal-delay:1">
        <p class="overline">What happens after you enquire</p>
        <ol class="expect-list" role="list">
          <li>
            <span class="expect-num overline tnum">01</span>
            <p class="muted">Your enquiry goes straight to the sales desk.</p>
          </li>
          <li>
            <span class="expect-num overline tnum">02</span>
            <p class="muted">We reply by call or WhatsApp first — within one working day.</p>
          </li>
          <li>
            <span class="expect-num overline tnum">03</span>
            <p class="muted">
              We confirm stock, today's price and delivery to your district, with GST invoice to
              your firm.
            </p>
          </li>
        </ol>
        <p class="expect-fast">
          Need it faster? <a class="tnum" href={`tel:${primaryPhone.tel}`}>Call {primaryPhone.display}</a> now.
        </p>
        <p class="small muted expect-hours tnum">Phone lines: {site.hours}</p>
      </div>
    </div>
  </section>

  <!-- #map — click-to-activate facade + Get Directions -->
  <section id="map" class="section--light cv-auto" aria-labelledby="map-h">
    <div class="container">
      <h2 id="map-h" class="display-2 sec-h" data-reveal>Find the plant.</h2>
      <div data-reveal style="--reveal-delay:1">
        <MapFacade />
      </div>
    </div>
  </section>

  <!-- #registered — compact legal strip -->
  <section id="registered" class="section--light hairline-top-light registered-sec" aria-labelledby="registered-h">
    <div class="container container--narrow">
      <h2 id="registered-h" class="h3 registered-h" data-reveal>Registered details.</h2>
      <div class="registered-card" data-reveal style="--reveal-delay:1">
        <p class="registered-name h4">{site.legalLine}</p>
        <p class="muted registered-addr">{site.address.lines[0]},<br />{site.address.lines[1]}</p>
        <p class="registered-gstin"><strong>GSTIN:</strong> <span class="tnum">{site.gstin}</span></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  section[id] {
    scroll-margin-top: calc(var(--header-h-mobile) + 12px);
  }

  /* ---------- #reach ---------- */
  .reach-hero {
    padding-top: calc(var(--header-h-mobile) + var(--sp-8));
  }
  @media (min-width: 1024px) {
    .reach-hero {
      padding-top: calc(var(--header-h) + var(--sp-8));
    }
  }
  .reach-title {
    margin-top: var(--sp-4);
    max-width: 18ch;
  }
  .reach-intro {
    margin-top: var(--sp-5);
    max-width: 52ch;
  }
  .reach-grid {
    list-style: none;
    padding: 0;
    margin: var(--sp-7) 0 0;
    display: grid;
    gap: var(--sp-5);
  }
  @media (min-width: 768px) {
    .reach-grid {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    }
  }
  .reach-card {
    padding: var(--sp-6);
    display: grid;
    gap: var(--sp-3);
    align-content: start;
    justify-items: start;
  }
  .card-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--r-pill);
    background: var(--def-tint);
    color: var(--blue-600);
    display: grid;
    place-items: center;
  }
  .card-title {
    margin-top: var(--sp-1);
  }
  .card-label {
    letter-spacing: 0.12em;
  }
  .phone-list {
    display: grid;
    gap: var(--sp-1);
  }
  .phone-row {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .phone-link {
    display: inline-flex;
    align-items: center;
    min-height: 48px;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--blue-600);
    text-decoration: none;
  }
  .phone-link:hover {
    text-decoration: underline;
    text-decoration-thickness: 2px;
  }
  .copy-btn {
    position: relative;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: var(--r-sm);
    color: var(--slate-500);
    transition: color var(--t-fast), background var(--t-fast);
  }
  .copy-btn:hover {
    color: var(--blue-600);
    background: rgba(27, 79, 156, 0.06);
  }
  .copy-btn .ic {
    display: grid;
    place-items: center;
  }
  .copy-btn :global(.icon-check) {
    display: none;
    color: var(--leaf-500);
  }
  .copy-btn.is-copied :global(.icon-copy) {
    display: none;
  }
  .copy-btn.is-copied :global(.icon-check) {
    display: block;
  }
  .copy-chip {
    position: absolute;
    bottom: calc(100% + 4px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: var(--ink-950);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: var(--r-pill);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--t-fast), transform var(--t-fast) var(--ease-out-soft);
  }
  .copy-btn.is-copied .copy-chip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .wa-note {
    max-width: 34ch;
  }
  .email-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--sp-2);
  }
  .email-list li {
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
    min-height: 32px;
  }
  .hours-line {
    font-weight: 600;
  }

  /* ---------- #form ---------- */
  .form-sec {
    position: relative;
    overflow: hidden;
  }
  .form-line {
    position: absolute;
    inset: auto 0 0 0;
    height: 50%;
    opacity: 0.25;
    pointer-events: none;
  }
  .form-line svg {
    width: 100%;
    height: 100%;
  }
  .form-split {
    position: relative;
    display: grid;
    gap: var(--sp-6);
    grid-template-areas: 'head' 'form' 'expect';
  }
  @media (min-width: 1024px) {
    .form-split {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      grid-template-rows: auto 1fr;
      grid-template-areas: 'head form' 'expect form';
      column-gap: var(--sp-8);
      align-items: start;
    }
  }
  .form-head {
    grid-area: head;
  }
  .form-head .display-2 {
    max-width: 14ch;
  }
  .form-col {
    grid-area: form;
  }
  .form-expect {
    grid-area: expect;
    display: grid;
    gap: var(--sp-5);
    align-content: start;
    max-width: 46ch;
  }
  .expect-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--sp-4);
  }
  .expect-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--sp-4);
    align-items: baseline;
    padding-top: var(--sp-4);
    border-top: 1px solid var(--hairline-dark);
  }
  .expect-num {
    color: var(--def-400);
  }
  .expect-fast {
    font-weight: 500;
  }
  .expect-hours {
    margin-top: calc(var(--sp-3) * -1);
  }

  /* ---------- #map ---------- */
  .sec-h {
    margin-bottom: var(--sp-7);
    max-width: 18ch;
  }

  /* ---------- #registered ---------- */
  .registered-sec {
    padding-block: var(--section-pad-strip);
  }
  .registered-h {
    margin-bottom: var(--sp-5);
  }
  .registered-card {
    background: #fff;
    border: 1px solid var(--hairline-light);
    border-radius: var(--r-md);
    padding: var(--sp-6);
    display: grid;
    gap: var(--sp-2);
  }
  @media (min-width: 768px) {
    .registered-card {
      grid-template-columns: 1fr auto;
      column-gap: var(--sp-6);
    }
    .registered-gstin {
      grid-column: 2;
      grid-row: 1;
      text-align: right;
    }
  }
</style>
