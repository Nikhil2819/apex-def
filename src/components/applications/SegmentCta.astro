---
// Segment CTA row (light bands) — content.md §3.4 per-segment CTA:
// "Call for Price" + WhatsApp Us (generic prefill; segments aren't a single
// pack, so the shared CtaRow's pack-prefill variant doesn't fit) + Enquire
// deep link, with the segment's verbatim WhatsApp note line beneath.
import { site, waLink } from '../../data/site.js';

interface Props {
  note?: string;
}

const { note } = Astro.props;
const primaryPhone = site.phones.find((p) => p.primary) ?? site.phones[0];
---

<div class="segment-cta">
  <div class="cta-row">
    <a class="btn btn--primary-light" href={`tel:${primaryPhone.tel}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      Call for Price
    </a>
    <a class="btn btn--whatsapp" href={waLink()} target="_blank" rel="noopener">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.7.8-.8 1-.2.2-.3.2-.6.1a6.7 6.7 0 0 1-3.3-2.9c-.3-.4 0-.5.1-.7l.5-.6c.1-.2.1-.3.2-.5s0-.4 0-.5c0-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3a3 3 0 0 0-1 2.2c0 1.3 1 2.6 1.1 2.8.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.2-.2-.5-.3z"/></svg>
      WhatsApp Us
    </a>
    <a class="btn btn--secondary-light" href="/contact#form">Enquire</a>
  </div>
  {note && <p class="cta-note small muted">{note}</p>}
</div>

<style>
  .segment-cta {
    display: grid;
    gap: var(--sp-3);
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-3);
  }
  @media (max-width: 479px) {
    .cta-row {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
