<script>
  // #norms-india carousel — progressive enhancement: dots nav + active sync.
  // Without JS the rail is a plain scroll-snap carousel (complete on its own).
  const rail = document.querySelector('[data-norms]');
  const dotsWrap = document.querySelector('[data-norms-dots]');
  if (rail && dotsWrap && 'IntersectionObserver' in window) {
    const cards = Array.from(rail.querySelectorAll('[data-norm-node]'));
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    dotsWrap.hidden = false;
    const dots = cards.map((card, i) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'norms-dot';
      b.setAttribute('aria-label', `Go to milestone ${i + 1} of ${cards.length}`);
      b.addEventListener('click', () => {
        card.scrollIntoView({
          behavior: reduce ? 'auto' : 'smooth',
          block: 'nearest',
          inline: 'center',
        });
      });
      dotsWrap.append(b);
      return b;
    });
    const setActive = (i: number) =>
      dots.forEach((d, j) => d.setAttribute('aria-current', j === i ? 'true' : 'false'));
    setActive(0);
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) setActive(cards.indexOf(entry.target));
        }
      },
      { root: rail, threshold: 0.6 }
    );
    cards.forEach((c) => io.observe(c));
  }
</script>

