---
interface Props { class?: string }
const { class: className = '' } = Astro.props;
---

<a href="/" class={`logo ${className}`} aria-label="APEX D.E.F — Diesel Exhaust Fluid, home">
  <svg class="logo-drop" width="22" height="28" viewBox="0 0 22 28" fill="none" aria-hidden="true">
    <defs>
      <linearGradient id="logoGrad" x1="0" y1="0" x2="22" y2="28" gradientUnits="userSpaceOnUse">
        <stop stop-color="#1B4F9C" />
        <stop offset="1" stop-color="#2FB6E9" />
      </linearGradient>
    </defs>
    <path
      d="M11 1.5C11 1.5 20.5 12.2 20.5 18.4C20.5 23.7 16.2 26.5 11 26.5C5.8 26.5 1.5 23.7 1.5 18.4C1.5 12.2 11 1.5 11 1.5Z"
      fill="url(#logoGrad)"
    />
    <path d="M7 19.5C7.4 21.4 8.9 22.8 11 23.1" stroke="rgba(255,255,255,.7)" stroke-width="1.6" stroke-linecap="round" fill="none" />
  </svg>
  <span class="logo-word">APEX <span class="logo-def">D.E.F</span></span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .logo-word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.375rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .logo-def {
    background: var(--grad-liquid);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
</style>
