---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="DEF Packs 5 L to Bulk | ISO 22241 Spec | APEX D.E.F"
  description="One ISO 22241 / IS 17042 fluid, six packs: 5 L, 10 L, 20 L, 210 L drum, 1000 L IBC, bulk tanker. Full published spec table. Call or WhatsApp for supply."
  path="/products"
>
  <section class="section--dark" style="padding-top: calc(var(--header-h-mobile) + var(--sp-8)); min-height: 60svh;">
    <div class="container">
      <p class="overline" data-reveal>Products</p>
      <h1 class="display-2" style="margin-top: var(--sp-4); max-width: 18ch;" data-reveal>One fluid. Six packs.</h1>
    </div>
  </section>
  <!-- Phase 2 fills the remaining sections per content.md -->
</BaseLayout>
