---
// #plant process walk — static/mobile base per design.md §4.2: VERTICAL timeline
// with a connecting flowing-liquid line (SVG) and 5 numbered steps. Step labels
// are the authoritative set from content.md §3.2 #plant; the three provided
// image captions attach to their steps. Authored vector process vignettes,
// 1.5px strokes, brand palette on dark.
//
// Motion-layer contracts (later phase): [data-process-walk] wraps the walk,
// [data-liquid-line] is the scrubbed spine, [data-process-step="n"] per step.

const METAL = '#8FA3B8';
const ACCENT = '#2FB6E9';
const TINT = 'rgba(47,182,233,0.10)';

const arts: string[] = [
  // 1 — Demineralise water: twin DM columns, manifold, outlet droplet.
  `<g fill="none" stroke="${METAL}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">` +
    `<rect x="20" y="26" width="16" height="44" rx="8" fill="${TINT}"/>` +
    `<rect x="46" y="26" width="16" height="44" rx="8" fill="${TINT}"/>` +
    `<path d="M28 26v-8h26v8M8 42h12M36 48h10M54 70v8h14"/>` +
    `</g>` +
    `<path d="M76 69c2.4 3 3.7 5.1 3.7 6.8a3.7 3.7 0 1 1-7.4 0c0-1.7 1.3-3.8 3.7-6.8Z" fill="${ACCENT}"/>`,
  // 2 — Dissolve automotive-grade urea: stirred batch vessel + urea hexagon.
  `<g fill="none" stroke="${METAL}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">` +
    `<path d="M26 26h44v26L56 66H40L26 52Z" fill="${TINT}"/>` +
    `<rect x="40" y="6" width="16" height="8" rx="2"/>` +
    `<path d="M48 14v36M40 44l16 8M40 52l16-8M48 66v10"/>` +
    `</g>` +
    `<path d="M30 40h36" stroke="${ACCENT}" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>` +
    `<path d="M76 20l8 4.6v9.2l-8 4.6-8-4.6v-9.2Z" fill="none" stroke="${ACCENT}" stroke-width="1.5" stroke-linejoin="round"/>` +
    `<circle cx="76" cy="20" r="1.6" fill="${ACCENT}"/>`,
  // 3 — Filter & circulate: cartridge housing + circulation arrows.
  `<g fill="none" stroke="${METAL}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">` +
    `<rect x="38" y="24" width="20" height="46" rx="10" fill="${TINT}"/>` +
    `<path d="M43 34h10M43 42h10M43 50h10M43 58h10"/>` +
    `</g>` +
    `<g fill="none" stroke="${ACCENT}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">` +
    `<path d="M48 19A28 28 0 0 0 20 47M20 47l-4.5-5.5M20 47l6.5-3"/>` +
    `<path d="M48 75a28 28 0 0 0 28-28M76 47l4.5 5.5M76 47l-6.5 3"/>` +
    `</g>`,
  // 4 — Lab clearance: flask with sample + droplet-check clearance badge.
  `<g fill="none" stroke="${METAL}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">` +
    `<path d="M40 14h16"/>` +
    `<path d="M44 14v14L30 58a7 7 0 0 0 6.4 10h23.2A7 7 0 0 0 66 58L52 28V14"/>` +
    `</g>` +
    `<path d="M37 50h22l4.6 9.3a6.6 6.6 0 0 1-6 9.7H38.4a6.6 6.6 0 0 1-6-9.7Z" fill="${TINT}"/>` +
    `<path d="M37 50h22" stroke="${ACCENT}" stroke-width="1.5" stroke-linecap="round"/>` +
    `<circle cx="72" cy="24" r="11" fill="rgba(6,11,20,0.6)" stroke="${ACCENT}" stroke-width="1.5"/>` +
    `<path d="m67 24 3.5 3.5 6.5-7" fill="none" stroke="${ACCENT}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  // 5 — Fill, seal, batch-code: nozzle, capped can with printed code, conveyor.
  `<path d="M42 16h12l-6 8Z" fill="${ACCENT}"/>` +
    `<g fill="none" stroke="${METAL}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">` +
    `<path d="M30 8h36M48 8v8"/>` +
    `<rect x="32" y="42" width="32" height="32" rx="5" fill="${TINT}"/>` +
    `<path d="M18 80h60"/>` +
    `<circle cx="26" cy="84" r="2.5"/><circle cx="48" cy="84" r="2.5"/><circle cx="70" cy="84" r="2.5"/>` +
    `</g>` +
    `<path d="M48 30v7" stroke="${ACCENT}" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="1.5 3.5"/>` +
    `<rect x="43" y="36" width="10" height="6" rx="2" fill="${ACCENT}"/>` +
    `<rect x="38" y="50" width="20" height="15" rx="2.5" fill="rgba(255,255,255,0.92)"/>` +
    `<path d="M41 55.5h14M41 59.5h9" stroke="#0A1B3D" stroke-width="1.5" stroke-linecap="round"/>`,
];

const steps = [
  { title: 'Demineralise water', caption: 'Demineralised water treatment stage' },
  {
    title: 'Dissolve automotive-grade urea',
    caption: 'Batch dissolution vessels — stainless steel contact surfaces',
  },
  { title: 'Filter & circulate', caption: null },
  { title: 'Lab clearance', caption: null },
  { title: 'Fill, seal, batch-code', caption: 'Filling line with tamper-evident capping' },
].map((s, i) => ({ ...s, art: arts[i] }));
---

<div class="process" data-process-walk>
  <svg
    class="process-spine"
    data-liquid-line
    aria-hidden="true"
    viewBox="0 0 48 800"
    preserveAspectRatio="none"
  >
    <defs>
      <linearGradient id="spine-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#2FB6E9" />
        <stop offset="1" stop-color="#1B4F9C" stop-opacity="0.35" />
      </linearGradient>
    </defs>
    <path
      d="M24 0C34 80 14 160 24 240C34 320 14 400 24 480C34 560 14 640 24 720L24 800"
      fill="none"
      stroke="url(#spine-grad)"
      stroke-width="2"
      vector-effect="non-scaling-stroke"></path>
  </svg>

  <ol class="process-steps">
    {
      steps.map((step, i) => (
        <li
          class="process-step"
          data-process-step={i + 1}
          data-reveal
          style={`--reveal-delay: ${i}`}
        >
          <span class="step-node tnum" aria-hidden="true">
            {i + 1}
          </span>
          <div class="step-text">
            <h3 class="h4">{step.title}</h3>
            {step.caption && <p class="small step-caption">{step.caption}</p>}
          </div>
          <svg class="step-art" viewBox="0 0 96 96" aria-hidden="true" set:html={step.art} />
        </li>
      ))
    }
  </ol>
</div>

<style>
  .process {
    position: relative;
    max-width: 820px;
  }
  .process-spine {
    position: absolute;
    left: 0;
    top: 12px;
    bottom: 12px;
    width: 48px;
    height: calc(100% - 24px);
    pointer-events: none;
  }
  .process-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
  }
  .process-step {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    align-items: center;
    gap: var(--sp-5);
    padding-block: var(--sp-6);
  }
  .process-step + .process-step {
    border-top: 1px solid var(--hairline-dark);
  }
  .step-node {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: var(--r-pill);
    background: var(--navy-800);
    border: 1px solid rgba(47, 182, 233, 0.4);
    color: var(--def-400);
    font-weight: 600;
    font-size: 1.125rem;
    position: relative;
    z-index: 1;
  }
  .step-text {
    display: grid;
    gap: var(--sp-2);
  }
  .step-text h3 {
    color: #fff;
  }
  .step-caption {
    color: rgba(255, 255, 255, 0.6);
    max-width: 42ch;
  }
  .step-art {
    width: clamp(64px, 10vw, 96px);
    height: auto;
    flex: 0 0 auto;
  }
  @media (max-width: 479px) {
    .process-step {
      grid-template-columns: 48px 1fr;
      row-gap: var(--sp-4);
    }
    .step-art {
      grid-column: 2;
      justify-self: start;
    }
  }
</style>
